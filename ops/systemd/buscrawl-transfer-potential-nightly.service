[Unit]
Description=Buscrawl transfer potential nightly aggregation
After=network-online.target buscrawl-derived-data-catchup.service
Wants=network-online.target

[Service]
Type=oneshot
User=eljah
WorkingDirectory=/home/eljah/apps/buscrawl
ExecStart=/home/eljah/apps/buscrawl/bin/run-transfer-potential-nightly.sh
StandardOutput=append:/home/eljah/apps/buscrawl/logs/transfer-potential-nightly.log
StandardError=append:/home/eljah/apps/buscrawl/logs/transfer-potential-nightly.log
